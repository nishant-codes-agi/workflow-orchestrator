{
  "name": "dag-orchestrator",
  "version": "1.0.0",
  "description": "DAG-based workflow orchestrator",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'"
  },
  "dependencies": {
    "fastify": "^5.3.3",
    "@fastify/sensible": "^6.0.3",
    "pg": "^8.16.0",
    "dotenv": "^16.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "@types/pg": "^8.15.4",
    "typescript": "^5.8.3",
    "tsx": "^4.19.4",
    "vitest": "^3.1.3",
    "eslint": "^9.27.0",
    "@eslint/js": "^9.27.0",
    "typescript-eslint": "^8.32.1",
    "prettier": "^3.5.3"
  }
}
